# Optional OpenRouter defaults
VITE_API_URL=https://openrouter.ai/api/v1
VITE_API_KEY=

# Optional RSS proxy for production builds.
# Supports either a template with {url} or a plain endpoint that accepts ?url=
# Example template: https://your-domain.com/api/rss?url={url}
# Example plain endpoint: https://your-domain.com/api/rss
VITE_RSS_PROXY_URL=
